    "      if (t[t[p].ls].sz >= k)",
    "        p = t[p].ls;",
    "      else {",
    "        k -= t[t[p].ls].sz + 1;",
    "        p = t[p].rs;",
    "      }",
    "    }",
    "    return T();",
    "  }",
    "  void update(int root, T l, T r, T v, int typ) {",
    "    int oldroot = root;",
    "    int x, y, z;",
    "    split(oldroot, l - 1, x, y);",
    "    split(y, r, y, z);",
    "    apply(y, v, typ);",
    "    return merge(merge(x, y), z);",
    "  }",
    "  int updateall(int root, T v, int typ) {",
    "    int oldroot = root;",
    "    int nRoot = clone(oldroot);",
    "    apply(nRoot, v, typ);",
    "    return nRoot;",
    "  }",
    "  Data query(int root, T l, T r) {",
    "    int x, y, z;",
    "    split(root, l - 1, x, y);",
    "    split(y, r, y, z);",
    "    Data res = t[y].info;",
    "    merge(merge(x, y), z);",
    "    return res;",
    "  }",
    "  Data queryall(int root) { return t[root].info; }",
    "  int count(int root, T v) {",
    "    int x, y, z;",
    "    split(root, v, x, z);",
    "    split(x, v - 1, x, y);",
    "    int res = t[y].sz;",
    "    merge(merge(x, y), z);",
