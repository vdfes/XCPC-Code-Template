    "      apply(p, add);",
    "      return;",
    "    }",
    "    pushdown(p);",
    "    int mid = t[p].l + t[p].r >> 1;",
    "    if (!t[p].ls) {",
    "      int ls = newnode(t[p].l, mid);",
    "      t[p].ls = ls;",
    "    }",
    "    if (!t[p].rs) {",
    "      int rs = newnode(mid + 1, t[p].r);",
    "      t[p].rs = rs;",
    "    }",
    "    update(t[p].ls, l, r, add), update(t[p].rs, l, r, add);",
    "    pushup(p);",
    "  }",
    "  data query(int p, int l, int r) {",
    "    if (!p)",
    "      return data();",
    "    if (r < t[p].l || t[p].r < l)",
